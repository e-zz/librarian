# ═══════════════════════════════════════════════════════════════════════════════
# librarian — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# On Windows:
#   copy .env.example .env
#
# All scripts load variables from .env automatically at startup.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────

# MinerU Cloud API token (v4 precision mode).
# Get yours at https://mineru.net — free tier available.
MINERU_TOKEN=your_token_here

# ── RAGFlow (optional) ────────────────────────────────────────────────────────

# Base URL of your RAGFlow instance.
# Default: http://localhost:9380
RAGFLOW_URL=http://localhost:9380

# RAGFlow API key — generated from RAGFlow UI > API Management.
# Required only when uploading to RAGFlow.
RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxx

# ── Directory Overrides (optional) ────────────────────────────────────────────

# Managed PDF library root — used by deposit.py for file placement.
MINERU_PDF_LIBRARY=./pdfs

# MinerU OCR output directory — parsed Markdown files land here.
MINERU_RAW_DIR=./_raw

# Download directory for pdf_downloader.py output.
MINERU_DOWNLOAD_DIR=./downloads

# API response cache directory — caches MinerU API responses to avoid
# re-parsing the same PDF on reruns.
MINERU_CACHE_DIR=~/.mineru_cache

# ── API Metadata (optional) ───────────────────────────────────────────────────

# Contact email sent in CrossRef User-Agent header.
# Helps CrossRef contact you if there are issues with your requests.
CONTACT_EMAIL=your.email@example.com

# Email required by the Unpaywall API for access.
UNPAYWALL_EMAIL=your.email@example.com
